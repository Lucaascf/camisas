# ============================================================
# FERRATO — Template de variáveis de ambiente
# Copie para .env e preencha com valores reais.
# NUNCA commite o .env com credenciais reais!
# ============================================================

# Ambiente: development | production
FLASK_ENV=production

# Chave secreta (OBRIGATÓRIA em produção — gere com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# ── Banco de Dados ──────────────────────────────────────────
# SQLite (padrão, bom para VPS com disco persistente):
# DATABASE_URL=sqlite:///ferrato.db
#
# PostgreSQL (necessário em Railway/Render — use a URL fornecida pelo serviço):
# DATABASE_URL=postgresql://user:password@host:5432/ferrato

# ── Email (Flask-Mail) ──────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-app-password-do-gmail
MAIL_DEFAULT_SENDER=seu-email@gmail.com

# ── Mercado Pago ────────────────────────────────────────────
# Sandbox (testes): MERCADOPAGO_SANDBOX=true
# Produção real:    MERCADOPAGO_SANDBOX=false
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_SANDBOX=true

# ── Melhor Envio ────────────────────────────────────────────
MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_SANDBOX=False
LOJA_CEP_ORIGEM=00000000

# ── URL pública da aplicação ────────────────────────────────
# Deixar vazio em desenvolvimento, preencher em produção
# Exemplo: https://ferrato.com.br
APP_BASE_URL=

# ── Painel Admin ────────────────────────────────────────────
# Chave de acesso ao painel administrativo
ADMIN_ACCESS_KEY=
